# Copy to .env and fill in. The .env file is gitignored.

# ── Supabase ────────────────────────────────────────────────────────────
# From Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://<your-project-ref>.supabase.co

# The publishable (anon) key works because RLS is disabled on the demo
# tables. For prod you'd switch to the service role key + RLS policies.
SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Postgres password. Used only by ad-hoc psql access; the app uses SUPABASE_KEY.
DB_PASSWORD=your-db-password

# ── LM Studio (local LLM, OpenAI-compatible) ────────────────────────────
# Start LM Studio, load a Gemma-3-4B class model, start the local server.
# The model id MUST match what `GET /v1/models` returns.
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=google/gemma-4-e4b

# ── CORS (optional) ─────────────────────────────────────────────────────
# Defaults to localhost:3000 and :3001. Override only if your FE runs elsewhere.
# CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
